description: |
    Bug summary: nginx supports PKCS#11 according to system policy
tag:
  - nginx:1.26
  - rhel-buildroot
  - rhel8-buildroot
tier: '1'
adjust:
  - enabled: false
    when: distro < rhel-8.10
    continue: false
  - enabled: false
    when: distro ~< rhel-9.6
    continue: false
component:
  - nginx:1.26
environment:
    MODSTREAMS: nginx:1.26
