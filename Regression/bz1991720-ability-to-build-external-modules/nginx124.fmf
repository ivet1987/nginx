tag:
  - NoModularTier
  - NoRHEL4
  - NoRHEL5
  - Tier3
  - rhel-buildroot
tier: '3'
adjust:
  - enabled: false
    when: product == rhel and distro < rhel-9
    continue: false
component:
  - nginx:1.24
environment:
    MODSTREAMS: nginx:1.24
extra-summary: /CoreOS/nginx/Regression/bz1991720-ability-to-build-external-modules
    [nginx:1.24]
