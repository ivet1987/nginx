contact: Ondrej Ptak <optak@redhat.com>
tag:
  - Tier3
adjust:
  - enabled: false
    when: distro < rhel-8.10
    continue: false
  - enabled: false
    when: distro ~< rhel-9.6
    continue: false
  - enabled: false
    when: deployment-mode == image
    continue: false
component:
  - nginx:1.26
environment:
    MODSTREAMS: nginx:1.26
