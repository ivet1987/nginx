component:
  - nginx:1.18
environment:
    MODSTREAMS: nginx:1.18
tag:
  - NoRHEL4
  - NoRHEL5
  - TestCaseCopy
adjust:
  - enabled: false
    when: distro < rhel-8
    continue: false
  - enabled: false
    when: distro ~< rhel-8.3
    continue: false
extra-nitrate: TC#0612679
extra-summary: /CoreOS/nginx/Regression/bz2015250-NGINX-logrotate-leads-to-gzip-stdin-file-size
    [nginx:1.18]
