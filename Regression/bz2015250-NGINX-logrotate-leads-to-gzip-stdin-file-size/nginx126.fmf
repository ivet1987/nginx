tag:
  - NoModularTier
  - Tier2
tier: '2'
adjust:
  - enabled: false
    when: distro < rhel-8.10
    continue: false
  - enabled: false
    when: distro ~< rhel-9.6
    continue: false
component:
  - nginx:1.24
environment:
    MODSTREAMS: nginx:1.26
extra-summary: /CoreOS/nginx/Regression/bz2015250-NGINX-logrotate-leads-to-gzip-stdin-file-size
    [nginx:1.24]
