tag:
  - NoModularTier
  - NoRHEL4
  - NoRHEL5
  - Tier2
tier: '2'
adjust:
  - enabled: false
    when: product == rhel and distro < rhel-9
    continue: false
  - enabled: false
    when: distro ~< rhel-9.1
    continue: false
component:
  - nginx:1.22
environment:
    MODSTREAMS: nginx:1.22
extra-nitrate: TC#0614414
extra-summary: /CoreOS/nginx/Regression/bz2099752-nginx-minimisation-for-ubi-micro
    [nginx:1.22]
