/:
    inherit: false

adjust:
  - when: trigger == commit
    enabled: false
    because: do not run this plan on MRs
  - when: newa_batch is defined
    report:
        how: reportportal

summary: Run all tests not requering buildroot

discover:
  - name: nginx
    how: fmf
    filter: "tag:-rhel-buildroot&tag:-rhel8-buildroot&tag:-rhel9-buildroot&tag:-nonewa&tag:-destructive&component:nginx"

execute:
    how: tmt
