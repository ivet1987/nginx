/:
    inherit: false
adjust:
  - when: trigger == commit
    enabled: false
    because: do not run the upgrade plan on PRs/MRs
  - when: initiator == newa
    enabled: false
    because: do not run for errata testing

summary: Basic upgrade test
discover:
    how: fmf
    filter: tag:upgrade
execute:
    how: upgrade
    url: https://gitlab.cee.redhat.com/oamg/rhel-major-upgrade
    upgrade-path: /paths/el8toel9.supported
