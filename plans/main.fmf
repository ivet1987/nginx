adjust:
  # configure brew repo for module erratum
  - when: brew_repo is defined and module_name is defined
    prepare+:
    - how: shell
      name: Get the repo with the module
      url: https://gitlab.cee.redhat.com/python-maint/prndl-qa
      script: cd $TMT_PREPARE_SHELL_URL_REPOSITORY && ./tmt-plans/_setup/cmr-repo/run.sh
