contact: Ondrej Ptak <optak@redhat.com>
tag:
  - Tier3
tier: '3'
adjust:
  - enabled: false
    when: distro < rhel-8.10
    continue: false
  - enabled: false
    when: distro ~< rhel-9.4
    continue: false
component:
  - nginx:1.24
environment:
    MODSTREAMS: nginx:1.24
extra-summary: /CoreOS/nginx/Sanity/ALPN_with_http2 [nginx:1.24]
