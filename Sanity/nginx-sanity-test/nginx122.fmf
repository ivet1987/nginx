tag:
  - Tier1
adjust:
  - enabled: false
    when: distro < rhel-8
    continue: false
  - enabled: false
    when: distro ~< rhel-9.2
    continue: false
  - when: deployment-mode == image
    enabled: false
    continue: false
component:
  - nginx:1.22
environment:
    MODSTREAMS: nginx:1.22
