contact: Ondrej Ptak <optak@redhat.com>
tag:
  - Tier2
  - notip
adjust:
  - enabled: false
    when: distro ~< rhel-6.4
    continue: false
  - enabled: false
    when: distro < rhel-9 and product != rhscl
    continue: false
component:
  - nginx:1.24
environment:
    MODSTREAMS: nginx:1.24
extra-summary: /CoreOS/nginx/Sanity/php-fpm-integration [nginx:1.24]
