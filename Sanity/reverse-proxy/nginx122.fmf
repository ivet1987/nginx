enabled: true
tag:
  - Tier1
tier: '1'
adjust:
  - enabled: false
    when: distro < rhel-9 and product != rhscl
    continue: false
  - enabled: false
    when: deployment-mode == image
    continue: false
component:
  - nginx:1.22
environment:
    MODSTREAMS: nginx:1.22
extra-nitrate: TC#0614403
extra-summary: /CoreOS/nginx/Sanity/reverse-proxy [nginx:1.22]
extra-hardware: |+
    MEMORY_MIN_16G

