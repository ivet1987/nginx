tag:
  - Tier1
tier: '1'
adjust:
  - enabled: false
    when: distro < rhel-8.10
    continue: false
  - enabled: false
    when: distro ~< rhel-9.6
    continue: false
  - enabled: false
    when: deployment-mode == image
    continue: false
component:
  - nginx:1.26
environment:
    MODSTREAMS: nginx:1.26
extra-hardware: |+
    MEMORY_MIN_16G

