tag:
  - Tier1
tier: '1'
adjust:
  - enabled: false
    when: distro < rhel-8.10
    continue: false
  - enabled: false
    when: distro ~< rhel-9.4
    continue: false
  - enabled: false
    when: deployment-mode == image
    continue: false
component:
  - nginx:1.24
environment:
    MODSTREAMS: nginx:1.24
extra-summary: /CoreOS/nginx/Sanity/reverse-proxy [nginx:1.24]
extra-hardware: |+
    MEMORY_MIN_16G

extra-nitrate: TC#0616794
id: fc03210f-c4c4-4587-b312-d3722bc40d3f
